{
  "name": "@stevenvincentone/intidev-agentloops-react",
  "version": "0.1.0",
  "description": "React components and hooks for IntiDev AgentLoops dashboards",
  "license": "MIT",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsx --test test/*.test.ts test/*.test.tsx",
    "prepublishOnly": "npm run typecheck && npm run build && npm test",
    "typecheck": "tsc -p tsconfig.tooling.json"
  },
  "keywords": [
    "agentic",
    "issue-tracking",
    "ticketing",
    "react",
    "dashboard",
    "components",
    "agent-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StevenVincentOne/IntiDev-AgentLoops.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/StevenVincentOne/IntiDev-AgentLoops/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/StevenVincentOne/IntiDev-AgentLoops/issues"
  },
  "author": {
    "name": "Inti / Steven Vincent"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
